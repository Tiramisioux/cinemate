{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Settings",
  "type": "object",
  "properties": {
    "i2c_oled": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "width": {
          "type": "integer",
          "default": 128
        },
        "height": {
          "type": "integer",
          "default": 64
        },
        "font_size": {
          "type": "integer",
          "default": 10
        },
        "values": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "iso",
                  "shutter_a",
                  "fps",
                  "wb_user",
                  "is_recording",
                  "resolution",
                  "cpu_load",
                  "cpu_temp",
                  "memory_usage",
                  "space_left"
                ]
              },
              {
                "type": "string"
              }
            ]
          }
        }
      }
    },
    "welcome_message": {
      "type": "string",
      "default": "THIS IS A COOL MACHINE"
    },
    "show_welcome_message": {
      "type": "boolean",
      "default": true
    },
    "welcome_image": {
      "anyOf": [{"type": "string"}, {"type": "null"}],
      "default": null
    },
    "lock_dual_recording": {
      "type": "boolean",
      "default": false,
      "description": "Dual-sensor rigs: true forces both sensors to record every take regardless of the HDMI preview (rec cam0/cam1 still overrides for one take); false makes recording follow the preview's main sensor, with side-by-side 'both' always recording both."
    },
    "audio": {
      "type": "object",
      "properties": {
        "24bit": {
          "type": "object",
          "description": "Settings for the 24-bit USB dsnoop path (RØDE NTG, mic_24bit alias)",
          "properties": {
            "capture_gain_db": { "type": "number", "default": 0.0 },
            "timecode_offset_frames": { "type": "integer", "default": 0 }
          }
        },
        "16bit": {
          "type": "object",
          "description": "Settings for the 16-bit plain-arecord fallback path (generic USB PnP mics)",
          "properties": {
            "capture_gain_db": { "type": "number", "default": 0.0 },
            "timecode_offset_frames": { "type": "integer", "default": 0 }
          }
        }
      },
      "additionalProperties": true
    },
    "settings": {
      "type": "object",
      "properties": {
        "auto_storage_preroll": {
          "type": "boolean",
          "default": true
        },
        "light_hz": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "conform_frame_rate": {
          "type": "number",
          "default": 24
        },
        "live_sync_warning_tolerance_frames": {
          "type": "number",
          "minimum": 0,
          "default": 2
        },
        "final_sync_analysis_tolerance_frames": {
          "type": "number",
          "minimum": 0,
          "default": 1
        }
      },
      "additionalProperties": true
    },
    "dynamic_resolution": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "profile": {
          "type": "string",
          "default": "default"
        },
        "profiles_file": {
          "type": "string",
          "default": "resources/dynamic_resolution_profiles.json"
        },
        "policy": {
          "type": "string",
          "enum": ["highest_sustainable_resolution"],
          "default": "highest_sustainable_resolution"
        },
        "safety_margin_fps": {
          "type": "number",
          "minimum": 0,
          "default": 0
        },
        "match_tolerance_px": {
          "type": "integer",
          "minimum": 0,
          "default": 32
        }
      },
      "additionalProperties": true
    },
    "sensors": {
      "type": "object",
      "properties": {
        "database_file": {
          "type": "string",
          "default": "resources/sensors.json"
        }
      },
      "additionalProperties": true
    },
    "camera": {
      "type": "object",
      "properties": {
        "cam0": { "$ref": "#/definitions/cam_config" },
        "cam1": { "$ref": "#/definitions/cam_config" }
      },
      "additionalProperties": true
    }
  },
  "definitions": {
    "cam_config": {
      "type": "object",
      "properties": {
        "phase_lock": {
          "type": "boolean",
          "description": "Enable the cinepi-raw frame-rate phase lock for this sensor (holds the recorded cadence on the nominal fps for stable A/V sync). Safe to leave enabled on multi-camera --sync genlock rigs: cinepi-raw runs the lock only on the master (--sync off/server) and the --sync client self-suppresses so libcamera's rpi.sync owns that sensor's VBLANK.",
          "default": true
        },
        "tuning_file_override": {
          "type": "object",
          "description": "Override the libcamera tuning file for this sensor",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "path": {
              "type": "string",
              "default": "resources/tuning_files/imx477.json"
            }
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
