{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Settings",
  "type": "object",
  "properties": {
    "i2c_oled": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "width": {
          "type": "integer",
          "default": 128
        },
        "height": {
          "type": "integer",
          "default": 64
        },
        "font_size": {
          "type": "integer",
          "default": 10
        },
        "values": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "iso",
                  "shutter_a",
                  "fps",
                  "wb_user",
                  "is_recording",
                  "resolution",
                  "cpu_load",
                  "cpu_temp",
                  "memory_usage",
                  "space_left"
                ]
              },
              {
                "type": "string"
              }
            ]
          }
        }
      }
    },
    "welcome_message": {
      "type": "string",
      "default": "THIS IS A COOL MACHINE"
    },
    "show_welcome_message": {
      "type": "boolean",
      "default": true
    },
    "welcome_image": {
      "anyOf": [{"type": "string"}, {"type": "null"}],
      "default": null
    },
    "audio": {
      "type": "object",
      "properties": {
        "capture_gain_db": {
          "type": "number",
          "default": 0.0
        },
        "plain_arecord_timecode_offset_frames": {
          "type": "integer",
          "default": 2
        }
      },
      "additionalProperties": true
    },
    "settings": {
      "type": "object",
      "properties": {
        "light_hz": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "conform_frame_rate": {
          "type": "number",
          "default": 24
        },
        "live_sync_warning_tolerance_frames": {
          "type": "number",
          "minimum": 0,
          "default": 2
        },
        "final_sync_analysis_tolerance_frames": {
          "type": "number",
          "minimum": 0,
          "default": 1
        }
      },
      "additionalProperties": true
    },
    "dynamic_resolution": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "profile": {
          "type": "string",
          "default": "default"
        },
        "profiles_file": {
          "type": "string",
          "default": "resources/dynamic_resolution_profiles.json"
        },
        "policy": {
          "type": "string",
          "enum": ["highest_sustainable_resolution"],
          "default": "highest_sustainable_resolution"
        },
        "safety_margin_fps": {
          "type": "number",
          "minimum": 0,
          "default": 0
        },
        "match_tolerance_px": {
          "type": "integer",
          "minimum": 0,
          "default": 32
        }
      },
      "additionalProperties": true
    },
    "sensors": {
      "type": "object",
      "properties": {
        "database_file": {
          "type": "string",
          "default": "resources/sensors.json"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
