{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Settings",
  "type": "object",
  "properties": {
    "i2c_oled": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "width": {
          "type": "integer",
          "default": 128
        },
        "height": {
          "type": "integer",
          "default": 64
        },
        "font_size": {
          "type": "integer",
          "default": 10
        },
        "values": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string",
                "enum": [
                  "iso",
                  "shutter_a",
                  "fps",
                  "wb_user",
                  "is_recording",
                  "resolution",
                  "cpu_load",
                  "cpu_temp",
                  "memory_usage",
                  "space_left"
                ]
              },
              {
                "type": "string"
              }
            ]
          }
        }
      }
    },
    "welcome_message": {
      "type": "string",
      "default": "THIS IS A COOL MACHINE"
    },
    "show_welcome_message": {
      "type": "boolean",
      "default": true
    },
    "welcome_image": {
      "anyOf": [{"type": "string"}, {"type": "null"}],
      "default": null
    },
    "audio": {
      "type": "object",
      "properties": {
        "capture_gain_db": {
          "type": "number",
          "default": 0.0
        }
      },
      "additionalProperties": true
    },
    "settings": {
      "type": "object",
      "properties": {
        "light_hz": {
          "type": "array",
          "items": {
            "type": "number"
          }
        },
        "conform_frame_rate": {
          "type": "number",
          "default": 24
        },
        "live_sync_warning_tolerance_frames": {
          "type": "number",
          "minimum": 0,
          "default": 2
        },
        "final_sync_analysis_tolerance_frames": {
          "type": "number",
          "minimum": 0,
          "default": 1
        }
      },
      "additionalProperties": true
    },
    "dynamic_resolution": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "profile": {
          "type": "string",
          "default": "default"
        },
        "profiles_file": {
          "type": "string",
          "default": "resources/dynamic_resolution_profiles.json"
        },
        "use_observed_profile": {
          "type": "boolean",
          "default": false
        },
        "observed_profile": {
          "type": "string",
          "default": "observed"
        },
        "observed_profiles_file": {
          "type": "string",
          "default": "src/dynamic_resolution_observed_profiles.json"
        },
        "policy": {
          "type": "string",
          "enum": ["highest_sustainable_resolution"],
          "default": "highest_sustainable_resolution"
        },
        "safety_margin_fps": {
          "type": "number",
          "minimum": 0,
          "default": 0
        },
        "match_tolerance_px": {
          "type": "integer",
          "minimum": 0,
          "default": 32
        },
        "learning": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": false
            },
            "minimum_duration_seconds": {
              "type": "number",
              "minimum": 0,
              "default": 10
            },
            "buffer_tolerance_frames": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            },
            "failure_backoff_fps": {
              "type": "number",
              "minimum": 0,
              "default": 1
            }
          },
          "additionalProperties": true
        },
        "performance_table": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sensor": {"type": "string"},
              "sensor_aliases": {
                "anyOf": [
                  {"type": "string"},
                  {"type": "array", "items": {"type": "string"}}
                ]
              },
              "storage_type": {
                "anyOf": [
                  {"type": "string"},
                  {"type": "array", "items": {"type": "string"}}
                ]
              },
              "filesystem": {"type": "string"},
              "media_model": {"type": "string"},
              "width": {"type": "integer"},
              "height": {"type": "integer"},
              "bit_depth": {
                "anyOf": [
                  {"type": "integer"},
                  {"type": "null"}
                ]
              },
              "max_fps_no_buffer": {"type": "number"},
              "max_fps": {"type": "number"},
              "sustainable_fps": {"type": "number"},
              "test_duration_seconds": {
                "anyOf": [
                  {"type": "number"},
                  {"type": "null"}
                ]
              },
              "buffer_peak_frames": {"type": "integer"},
              "drop_frames": {"type": "integer"},
              "confidence": {"type": "string"},
              "notes": {"type": "string"}
            },
            "required": ["sensor", "storage_type", "filesystem", "width", "height"],
            "additionalProperties": true
          },
          "default": []
        }
      },
      "additionalProperties": true
    },
    "sensors": {
      "type": "object",
      "properties": {
        "database_file": {
          "type": "string",
          "default": "resources/sensors.json"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
